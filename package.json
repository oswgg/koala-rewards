{
  "name": "koalacards",
  "version": "0.0.1",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter @koalacards/web dev",
    "build": "bun run --filter @koalacards/web build",
    "start": "bun run --filter @koalacards/web start",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter @koalacards/web lint",
    "format": "bun run --filter @koalacards/web format"
  }
}
