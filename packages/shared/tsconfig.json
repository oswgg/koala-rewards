{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["esnext", "dom"],
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@ui/*": ["./*"],
            "@vado/shared/ui": ["ui/index.ts"],
            "@vado/shared/ui/*": ["ui/*"]
        }
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["node_modules"]
}
